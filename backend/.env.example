# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev — zero setup)
DATABASE_URL="file:../prisma/dev.db"

# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@host:5432/locastay?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-64-char-secret-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS — comma-separated frontend origins ───────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,https://locastay.in"

# ── File uploads ──────────────────────────────────────────────────────────────
# Where uploaded files are stored (served at /uploads/*)
UPLOAD_DIR="./uploads"

# ── Email (optional — Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=""
