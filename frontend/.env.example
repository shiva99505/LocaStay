# ── Supabase (REQUIRED — Supabase Dashboard → Settings → API) ────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# ── Supabase Service Role (REQUIRED for server-side admin operations) ─────────
# Dashboard → Settings → API → service_role  (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ── Backend API (Express server) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LocaStay"
