# ──────────────────────────────────────────────────────────────────────
# LocaStay — environment configuration
#
# Copy this file to `.env.local` and fill in your credentials.
# NEXT_PUBLIC_* variables are exposed to the browser.
# All others are server-only.
# ──────────────────────────────────────────────────────────────────────

# ── Supabase (primary database + auth + storage) ─────────────────────
# Get these from: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"          # safe to expose in browser
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"       # NEVER expose in browser

# ── Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ─
# WEBHOOK_SECRET="<random-secret>"   # matches the DB Webhook Authorization header
# CRON_SECRET="<random-secret>"      # protects the rent-reminder cron endpoint
# RESEND_API_KEY="<key>"             # https://resend.com — for transactional email

# ── Legacy / local dev (Prisma + Auth.js) ────────────────────────────
# Keep for local SQLite dev; remove when fully migrated to Supabase.
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"
NEXTAUTH_URL="http://localhost:3000"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Maps ────────────────────────────────────────────────────────────────
# Without a key: location is shown via a Leaflet/OpenStreetMap embed plus
# Google Maps deep-links (no key required for "Get Directions"/"Open in Maps").
# With a key: enables the richer @googlemaps JS widgets.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── Media storage (Cloudinary) ──────────────────────────────────────────
# Without keys: uploads are stored as optimized data-URLs in the database
# (fine for demos). With keys: media is uploaded to Cloudinary's CDN.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Payments (Razorpay) ──────────────────────────────────────────────────
# Without keys: rent payments run through a "Simulated UPI" flow that
# produces real receipts/ledger rows. With keys: real Razorpay Checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ── WhatsApp Business / Notifications ────────────────────────────────────
# Without a token: "Message on WhatsApp" buttons use wa.me deep-links
# (genuinely functional, no API needed) and reminders land in-app.
# With a token: server-side template messages via the Graph API.
WHATSAPP_BUSINESS_PHONE_ID=""
WHATSAPP_BUSINESS_ACCESS_TOKEN=""
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER="919876500000"

# ── Email / SMS (optional, used by the notification fan-out service) ─────
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
