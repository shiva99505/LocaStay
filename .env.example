# Database
DATABASE_URL="postgresql://user:password@localhost:5432/locastay"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxx

# Cloudinary Media
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxx

# Razorpay Payments
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx

# WhatsApp Business API
WHATSAPP_BUSINESS_PHONE_ID=1234567890
WHATSAPP_BUSINESS_ACCESS_TOKEN=xxxxxxxxxxxx

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_S3_BUCKET=locastay-backups

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_VOICE_SEARCH=true
ENABLE_BULK_UPLOAD=false
ENABLE_PAYMENT_GATEWAY=false

# Logging & Monitoring
LOG_LEVEL=debug
SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxx
